<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.vaycore.finance.ui.views.StyledLinearLayout
        android:id="@+id/cardLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_20"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:radius="@dimen/dp_8"
        app:solidColor="@color/white">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="@dimen/dp_162"
            android:layout_height="@dimen/dp_101"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/dp_15"
            android:src="@mipmap/bg_home_overdue" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_16"
            android:layout_marginTop="@dimen/dp_19"
            android:gravity="center"
            android:text="@string/pre_credit_has_expired"
            android:textColor="@color/C_111827"
            android:textSize="@dimen/sp_16"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_16"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_marginBottom="@dimen/dp_30"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:text="@string/dialog_home_refuse"
            android:textColor="@color/C_6D7280"
            android:textSize="@dimen/sp_12" />
    </com.vaycore.finance.ui.views.StyledLinearLayout>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivClose"
        android:layout_width="@dimen/dp_30"
        android:layout_height="@dimen/dp_30"
        android:layout_marginTop="@dimen/dp_28"
        android:importantForAccessibility="no"
        android:src="@mipmap/ic_dialog_bottom_close"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardLayout" />

</androidx.constraintlayout.widget.ConstraintLayout>
