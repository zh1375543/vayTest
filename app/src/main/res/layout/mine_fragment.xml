<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context=".ui.fragments.MineFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/dp_24">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivAvatar"
            android:layout_width="@dimen/dp_64"
            android:layout_height="@dimen/dp_64"
            android:layout_marginStart="@dimen/dp_24"
            android:layout_marginTop="@dimen/dp_40"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_mine_header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_10"
            android:layout_marginEnd="@dimen/dp_24"
            android:includeFontPadding="false"
            android:text="@string/welcome"
            android:textColor="@color/C_374151"
            android:textSize="@dimen/sp_12"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/tvPhone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivAvatar"
            app:layout_constraintTop_toTopOf="@id/ivAvatar"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_6"
            android:includeFontPadding="false"
            android:textColor="@color/C_374151"
            android:textSize="@dimen/sp_15"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/ivAvatar"
            app:layout_constraintEnd_toEndOf="@id/tvWelcome"
            app:layout_constraintStart_toStartOf="@id/tvWelcome"
            app:layout_constraintTop_toBottomOf="@id/tvWelcome"
            tools:text="91885445888" />

        <LinearLayout
            android:id="@+id/profileShortcutRow"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_90"
            android:layout_marginStart="@dimen/dp_24"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_marginEnd="@dimen/dp_24"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivAvatar">

            <FrameLayout
                android:id="@+id/tvAccount"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/dp_8"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <com.vaycore.finance.ui.views.StyledLinearLayout
                    style="@style/MineShortcutCardBackground" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_52"
                    android:layout_height="@dimen/dp_52"
                    android:layout_gravity="top|center_horizontal"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/ic_tab_mine_account" />

                <TextView
                    style="@style/MineShortcutLabel"
                    android:layout_gravity="bottom"
                    android:layout_marginBottom="@dimen/dp_8"
                    android:text="@string/accounts" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tvOrder"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/dp_4"
                android:layout_marginEnd="@dimen/dp_4"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <com.vaycore.finance.ui.views.StyledLinearLayout
                    style="@style/MineShortcutCardBackground" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_52"
                    android:layout_height="@dimen/dp_52"
                    android:layout_gravity="top|center_horizontal"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/ic_tab_mine_order" />

                <TextView
                    style="@style/MineShortcutLabel"
                    android:layout_gravity="bottom"
                    android:layout_marginBottom="@dimen/dp_8"
                    android:text="@string/order_center" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tvCert"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/dp_8"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <com.vaycore.finance.ui.views.StyledLinearLayout
                    style="@style/MineShortcutCardBackground" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_52"
                    android:layout_height="@dimen/dp_52"
                    android:layout_gravity="top|center_horizontal"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/ic_tab_mine_certification" />

                <TextView
                    style="@style/MineShortcutLabel"
                    android:layout_gravity="bottom"
                    android:layout_marginBottom="@dimen/dp_8"
                    android:text="@string/certification" />
            </FrameLayout>
        </LinearLayout>

        <com.vaycore.finance.ui.views.StyledLinearLayout
            android:id="@+id/tvQuick"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_24"
            android:layout_marginTop="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_24"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/dp_10"
            app:radius="@dimen/dp_18"
            app:strokeWidth="1dp"
            app:solidColor="@color/C_F6F6F6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileShortcutRow">

            <com.vaycore.finance.ui.views.StyledLinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_50"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/dp_14"
                android:paddingEnd="@dimen/dp_8"
                app:radius="@dimen/dp_15"
                app:solidColor="@color/white">

                <TextView
                    android:id="@+id/tvQuickText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:includeFontPadding="false"
                    android:text="@string/quick_repayment"
                    android:textColor="@color/C_374151"
                    android:textSize="@dimen/sp_16"
                    android:textStyle="bold" />

                <com.vaycore.finance.ui.views.StyledTextView
                    android:id="@+id/tvPayBack"
                    android:layout_width="@dimen/dp_96"
                    android:layout_height="@dimen/dp_36"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/pay_back_now"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_12"
                    android:textStyle="bold"
                    app:radius="@dimen/dp_18"
                    app:solidColor="@color/color_7087F8" />
            </com.vaycore.finance.ui.views.StyledLinearLayout>
        </com.vaycore.finance.ui.views.StyledLinearLayout>

        <LinearLayout
            android:id="@+id/profileMenuContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_24"
            android:layout_marginTop="@dimen/dp_10"
            android:layout_marginEnd="@dimen/dp_24"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvQuick">


            <FrameLayout
                android:id="@+id/tvPolicy"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48"
                android:clickable="true"
                android:focusable="true">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_24"
                    android:layout_height="@dimen/dp_24"
                    android:layout_gravity="start|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/ic_tab_mine_privacy" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:paddingStart="@dimen/dp_34"
                    android:paddingEnd="@dimen/dp_24"
                    android:text="@string/privacy_policy"
                    android:textColor="@color/C_374151"
                    android:textSize="@dimen/sp_13"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_16"
                    android:layout_height="@dimen/dp_16"
                    android:layout_gravity="end|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/mine_right" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tvSettings"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48"
                android:clickable="true"
                android:focusable="true">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_24"
                    android:layout_height="@dimen/dp_24"
                    android:layout_gravity="start|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/ic_tab_mine_set" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:paddingStart="@dimen/dp_34"
                    android:paddingEnd="@dimen/dp_24"
                    android:text="@string/settings"
                    android:textColor="@color/C_374151"
                    android:textSize="@dimen/sp_13"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_16"
                    android:layout_height="@dimen/dp_16"
                    android:layout_gravity="end|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/mine_right" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tvContactUs"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48"
                android:clickable="true"
                android:focusable="true">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_24"
                    android:layout_height="@dimen/dp_24"
                    android:layout_gravity="start|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/ic_tab_mine_contact" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:paddingStart="@dimen/dp_34"
                    android:paddingEnd="@dimen/dp_24"
                    android:text="@string/contact_us"
                    android:textColor="@color/C_374151"
                    android:textSize="@dimen/sp_13"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_16"
                    android:layout_height="@dimen/dp_16"
                    android:layout_gravity="end|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/mine_right" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tvAboutUs"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48"
                android:clickable="true"
                android:focusable="true">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_24"
                    android:layout_height="@dimen/dp_24"
                    android:layout_gravity="start|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/ic_tab_mine_about" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:paddingStart="@dimen/dp_34"
                    android:paddingEnd="@dimen/dp_24"
                    android:text="@string/about_us"
                    android:textColor="@color/C_374151"
                    android:textSize="@dimen/sp_13"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_16"
                    android:layout_height="@dimen/dp_16"
                    android:layout_gravity="end|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/mine_right" />
            </FrameLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
