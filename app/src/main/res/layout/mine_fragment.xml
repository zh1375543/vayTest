<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/C_F6F6F6"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context=".ui.fragments.MineFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/dp_24">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/profileHeaderBg"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_164"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_mine_header_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivAvatar"
            android:layout_width="@dimen/dp_72"
            android:layout_height="@dimen/dp_72"
            android:layout_marginStart="@dimen/dp_31"
            android:layout_marginTop="@dimen/dp_59"
            android:src="@mipmap/ic_mine_header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_6"
            android:layout_marginEnd="@dimen/dp_24"
            android:includeFontPadding="false"
            android:text="@string/welcome"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_12"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/tvPhone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivAvatar"
            app:layout_constraintTop_toTopOf="@id/ivAvatar"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_7"
            android:includeFontPadding="false"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_15"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/ivAvatar"
            app:layout_constraintEnd_toEndOf="@id/tvWelcome"
            app:layout_constraintStart_toStartOf="@id/tvWelcome"
            app:layout_constraintTop_toBottomOf="@id/tvWelcome"
            tools:text="91885445888" />

        <FrameLayout
            android:id="@+id/tvQuick"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_61"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_15"
            android:background="@mipmap/ic_mine_content_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileHeaderBg">

            <TextView
                android:id="@+id/tvQuickText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="@dimen/dp_20"
                android:includeFontPadding="false"
                android:text="@string/quick_repayment"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold" />

            <com.vaycore.finance.ui.views.StyledTextView
                android:id="@+id/tvPayBack"
                android:layout_width="@dimen/dp_130"
                android:layout_height="@dimen/dp_36"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="@dimen/dp_18"
                android:gravity="center"
                android:text="@string/pay_back_now"
                android:textColor="@color/C_111827"
                android:textSize="@dimen/sp_12"
                android:textStyle="bold"
                app:radius="@dimen/dp_18"
                app:solidColor="@color/C_89F5C7" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/profileShortcutRow"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_90"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_15"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvQuick">

            <com.vaycore.finance.ui.views.StyledLinearLayout
                android:id="@+id/tvAccount"
                android:layout_width="@dimen/dp_0"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/dp_8"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="@dimen/dp_8"
                android:paddingBottom="@dimen/dp_7"
                app:radius="@dimen/dp_8"
                app:solidColor="@color/white">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_58"
                    android:layout_height="@dimen/dp_58"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/ic_mine_account" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_17"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/accounts"
                    android:textColor="@color/C_111827"
                    android:textSize="@dimen/sp_12"
                    android:textStyle="bold" />
            </com.vaycore.finance.ui.views.StyledLinearLayout>

            <com.vaycore.finance.ui.views.StyledLinearLayout
                android:id="@+id/tvOrder"
                android:layout_width="@dimen/dp_0"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="@dimen/dp_4"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="@dimen/dp_8"
                android:paddingBottom="@dimen/dp_7"
                app:radius="@dimen/dp_8"
                app:solidColor="@color/white">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_58"
                    android:layout_height="@dimen/dp_58"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/ic_mine_order" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_17"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/order_center"
                    android:textColor="@color/C_111827"
                    android:textSize="@dimen/sp_12"
                    android:textStyle="bold" />
            </com.vaycore.finance.ui.views.StyledLinearLayout>

            <com.vaycore.finance.ui.views.StyledLinearLayout
                android:id="@+id/tvCert"
                android:layout_width="@dimen/dp_0"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/dp_8"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="@dimen/dp_8"
                android:paddingBottom="@dimen/dp_7"
                app:radius="@dimen/dp_8"
                app:solidColor="@color/white">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_58"
                    android:layout_height="@dimen/dp_58"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/ic_mine_cer" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_17"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/certification"
                    android:textColor="@color/C_111827"
                    android:textSize="@dimen/sp_12"
                    android:textStyle="bold" />
            </com.vaycore.finance.ui.views.StyledLinearLayout>
        </LinearLayout>

        <com.vaycore.finance.ui.views.StyledLinearLayout
            android:id="@+id/profileMenuContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_10"
            android:orientation="vertical"
            android:paddingTop="@dimen/dp_7"
            android:paddingBottom="@dimen/dp_7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileShortcutRow"
            app:radius="@dimen/dp_8"
            app:solidColor="@color/white">

            <TextView
                android:id="@+id/tvPolicy"
                style="@style/PersonalMenuItemText"
                android:text="@string/privacy_policy"
                app:drawableStartCompat="@mipmap/ic_mine_privacy" />

            <TextView
                android:id="@+id/tvSettings"
                style="@style/PersonalMenuItemText"
                android:text="@string/settings"
                app:drawableStartCompat="@mipmap/ic_mine_setting" />

            <TextView
                android:id="@+id/tvContactUs"
                style="@style/PersonalMenuItemText"
                android:text="@string/contact_us"
                app:drawableStartCompat="@mipmap/ic_mine_contract" />

            <TextView
                android:id="@+id/tvAboutUs"
                style="@style/PersonalMenuItemText"
                android:text="@string/about_us"
                app:drawableStartCompat="@mipmap/ic_mine_about" />
        </com.vaycore.finance.ui.views.StyledLinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
