<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <androidx.appcompat.widget.AppCompatImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:importantForAccessibility="no"
        android:scaleType="fitXY"
        android:src="@mipmap/ic_dialog_credit_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivLeftCoin"
        android:layout_width="@dimen/dp_82"
        android:layout_height="wrap_content"
        android:layout_marginStart="-15dp"
        android:layout_marginTop="@dimen/dp_12"
        android:importantForAccessibility="no"
        android:src="@mipmap/ic_dialog_credit_left"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivCredit"
        android:layout_width="@dimen/dp_94"
        android:layout_height="@dimen/dp_94"
        android:layout_marginStart="@dimen/dp_26"
        android:layout_marginTop="@dimen/dp_6"
        android:importantForAccessibility="no"
        android:src="@mipmap/ic_dialog_credit_img"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="@dimen/dp_0"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_24"
        android:layout_marginEnd="@dimen/dp_24"
        android:layout_marginTop="@dimen/dp_42"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="@string/credit_dialog_title"
        android:textColor="@color/C_374151"
        android:textSize="@dimen/sp_16"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvAmount"
        android:layout_width="@dimen/dp_0"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_4"
        android:layout_marginEnd="@dimen/dp_24"
        android:layout_marginTop="@dimen/dp_25"
        android:gravity="left"
        android:includeFontPadding="false"
        android:text="500,000,000₫"
        android:textColor="@color/C_111827"
        android:textSize="@dimen/sp_25"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivCredit"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <TextView
        android:id="@+id/tvAmountLabel"
        android:layout_width="@dimen/dp_0"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_4"
        android:layout_marginEnd="@dimen/dp_24"
        android:layout_marginTop="@dimen/dp_5"
        android:gravity="left"
        android:text="@string/credit_dialog_available_amount"
        android:textColor="@color/C_374151"
        android:textSize="@dimen/sp_14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivCredit"
        app:layout_constraintTop_toBottomOf="@id/tvAmount" />

    <com.vaycore.finance.ui.views.StyledConstraintLayout
        android:id="@+id/benefitsLayout"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_113"
        android:layout_marginHorizontal="@dimen/dp_28"
        android:layout_marginTop="@dimen/dp_5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivCredit"
        app:radius="@dimen/dp_20"
        app:solidColor="#F1F5FF"
        app:strokeColor="#E0E9FF"
        app:strokeWidth="@dimen/dp_1">

        <TextView
            android:id="@+id/tvBenefitsTitle"
            android:layout_width="@dimen/dp_0"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_18"
            android:layout_marginTop="@dimen/dp_12"
            android:text="@string/credit_dialog_benefits_title"
            android:textColor="@color/C_374151"
            android:textSize="@dimen/sp_17"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/benefitList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_6"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvBenefitsTitle">

            <include layout="@layout/credit_dialog_benefit_fast_application" />
            <include layout="@layout/credit_dialog_benefit_quick_review" />
            <include layout="@layout/credit_dialog_benefit_funds_after_approval" />
        </LinearLayout>
    </com.vaycore.finance.ui.views.StyledConstraintLayout>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivRightCoin"
        android:layout_width="@dimen/dp_82"
        android:layout_height="@dimen/dp_0"
        android:layout_marginEnd="@dimen/dp_m_10"
        android:importantForAccessibility="no"
        android:scaleType="fitXY"
        android:src="@mipmap/ic_dialog_credit_right"
        app:layout_constraintBottom_toBottomOf="@id/btnWithdraw"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <com.vaycore.finance.ui.widget.ActionButtonView
        android:id="@+id/btnWithdraw"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_48"
        android:layout_marginHorizontal="@dimen/dp_28"
        android:layout_marginTop="@dimen/dp_10"
        android:gravity="center"
        android:text="@string/withdraw_now"
        android:textSize="@dimen/sp_18"
        android:textStyle="bold"
        app:buttonTextColor="@color/C_111827"
        app:buttonSolidColor="@color/C_89F5C7"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/benefitsLayout" />

    <androidx.appcompat.widget.AppCompatImageView
        android:layout_width="@dimen/dp_52"
        android:layout_height="@dimen/dp_48"
        android:layout_marginTop="@dimen/dp_15"
        android:importantForAccessibility="no"
        android:src="@mipmap/ic_dialog_onclick"
        app:layout_constraintEnd_toEndOf="@id/btnWithdraw"
        app:layout_constraintTop_toTopOf="@id/btnWithdraw" />

    <TextView
        android:id="@+id/tvLater"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sp_5"
        android:gravity="center"
        android:paddingHorizontal="@dimen/dp_10"
        android:text="@string/credit_dialog_later"
        android:textColor="@color/C_374151"
        android:textSize="@dimen/sp_16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnWithdraw" />
    <View
        android:layout_width="0dp"
        android:layout_height="@dimen/dp_10"
        app:layout_constraintTop_toBottomOf="@id/tvLater"
        tools:ignore="MissingConstraints" />
</androidx.constraintlayout.widget.ConstraintLayout>
