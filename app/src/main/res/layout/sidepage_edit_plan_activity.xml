<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@mipmap/ic_page_bg">

    <com.vaycore.finance.ui.views.PageHeaderView
        android:id="@+id/titleBar"
        android:layout_width="0dp"
        android:layout_height="@dimen/dp_56"
        app:centerText="@string/portal_edit_plan_title"
        app:fitStatusBar="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingStart="@dimen/dp_16"
        android:paddingTop="@dimen/dp_12"
        android:paddingEnd="@dimen/dp_16"
        android:paddingBottom="@dimen/dp_20"
        app:layout_constraintBottom_toTopOf="@id/bottomActionLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleBar">

        <com.vaycore.finance.ui.views.StyledLinearLayout
            android:id="@+id/formCard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="@dimen/dp_10"
            android:paddingTop="@dimen/dp_20"
            android:paddingEnd="@dimen/dp_10"
            android:paddingBottom="@dimen/dp_24"
            app:radius="@dimen/dp_24"
            app:solidColor="@color/white">

            <com.vaycore.finance.ui.widget.FormItemView
                android:id="@+id/planNameView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:editMaxLength="50"
                app:errorText="@string/portal_please_enter_plan_name"
                app:formType="input"
                app:hintText="@string/please_enter"
                app:inputBackgroundColor="@color/C_F6F6F6"
                app:inputType="text"
                app:titleText="@string/portal_plan_name" />

            <TextView
                android:id="@+id/tvRecordPhotoLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_16"
                android:layout_marginTop="@dimen/dp_16"
                android:text="@string/portal_record_photo"
                android:textColor="@color/C_374151"
                android:textSize="@dimen/sp_14" />

            <LinearLayout
                android:id="@+id/photoLayout"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_104"
                android:layout_marginStart="@dimen/dp_16"
                android:layout_marginTop="@dimen/dp_10"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/photoPreviewContainer"
                    android:layout_width="@dimen/dp_104"
                    android:layout_height="@dimen/dp_104"
                    android:layout_marginEnd="@dimen/dp_8"
                    android:padding="@dimen/dp_4"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivPlanPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/portal_record_photo"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/Round_8"
                        tools:src="@mipmap/ic_as_defalut" />

                    <ImageView
                        android:id="@+id/ivDeletePhoto"
                        android:layout_width="@dimen/dp_20"
                        android:layout_height="@dimen/dp_20"
                        android:layout_gravity="top|end"
                        android:contentDescription="@null"
                        android:src="@mipmap/ic_as_close" />

                </FrameLayout>

                <com.vaycore.finance.ui.views.StyledConstraintLayout
                    android:id="@+id/photoUploadView"
                    android:layout_width="@dimen/dp_104"
                    android:layout_height="@dimen/dp_104"
                    app:autoFillPressedColor="true"
                    app:radius="@dimen/dp_18"
                    app:solidColor="@color/C_F6F6F6">

                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:contentDescription="@string/portal_record_photo"
                        android:padding="@dimen/dp_36"
                        android:scaleType="centerCrop"
                        android:src="@mipmap/ic_at_upload"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </com.vaycore.finance.ui.views.StyledConstraintLayout>

            </LinearLayout>

        </com.vaycore.finance.ui.views.StyledLinearLayout>

    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomActionLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/dp_16"
        android:paddingTop="@dimen/dp_12"
        android:paddingEnd="@dimen/dp_16"
        android:paddingBottom="@dimen/dp_16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.vaycore.finance.ui.widget.ActionButtonView
            android:id="@+id/btAbandonPlan"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_52"
            android:layout_marginEnd="@dimen/dp_10"
            android:layout_weight="1"
            android:text="@string/portal_abandon_plan"
            android:textSize="@dimen/sp_14"
            app:actionButtonVariant="outline"
            app:buttonStrokeColor="@color/C_F62909"
            app:buttonTextColor="@color/C_F62909" />

        <com.vaycore.finance.ui.widget.ActionButtonView
            android:id="@+id/btEditPlan"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_52"
            android:layout_marginStart="@dimen/dp_10"
            android:layout_weight="1"
            android:text="@string/portal_edit_plan_button"
            android:textSize="@dimen/sp_14"
            app:actionButtonVariant="filled" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
