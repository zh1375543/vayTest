<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/dp_24"
        android:paddingTop="@dimen/dp_24"
        android:paddingEnd="@dimen/dp_24"
        android:paddingBottom="@dimen/dp_24">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_64"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivAvatar"
                android:layout_width="@dimen/dp_64"
                android:layout_height="@dimen/dp_64"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_mine_header" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/dp_10"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/welcome"
                    android:textColor="@color/C_374151"
                    android:textSize="@dimen/sp_16"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:includeFontPadding="false"
                    android:textColor="@color/C_374151"
                    android:textSize="@dimen/sp_20"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/ratingCard"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_110"
            android:layout_marginTop="@dimen/dp_20">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@mipmap/ic_as_content_bg" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_20"
                android:layout_marginTop="@dimen/dp_18"
                android:layout_marginEnd="@dimen/dp_110"
                android:includeFontPadding="false"
                android:text="@string/account_rate_message"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_13"
                android:textStyle="italic" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_20"
                android:layout_marginTop="@dimen/dp_36"
                android:layout_marginEnd="@dimen/dp_110"
                android:includeFontPadding="false"
                android:text="@string/account_rate_prompt"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold" />

            <com.vaycore.finance.ui.views.StyledTextView
                android:id="@+id/tvRate"
                android:layout_width="@dimen/dp_96"
                android:layout_height="@dimen/dp_36"
                android:layout_gravity="start|bottom"
                android:layout_marginStart="@dimen/dp_20"
                android:layout_marginBottom="@dimen/dp_12"
                android:gravity="center"
                android:text="@string/rate"
                android:textColor="@color/color_7087F8"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold"
                app:radius="@dimen/dp_18"
                app:solidColor="@color/white" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_18"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/tvShareApp"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_56"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:layout_gravity="start|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/ic_as_mine_share" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:paddingStart="@dimen/dp_44"
                    android:paddingEnd="@dimen/dp_32"
                    android:text="@string/share_app"
                    android:textColor="@color/C_374151"
                    android:textSize="@dimen/sp_16" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_24"
                    android:layout_height="@dimen/dp_24"
                    android:layout_gravity="end|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/mine_right" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tvSettings"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_56"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:layout_gravity="start|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/ic_tab_mine_set" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:paddingStart="@dimen/dp_44"
                    android:paddingEnd="@dimen/dp_32"
                    android:text="@string/settings"
                    android:textColor="@color/C_374151"
                    android:textSize="@dimen/sp_16" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_24"
                    android:layout_height="@dimen/dp_24"
                    android:layout_gravity="end|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/mine_right" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tvHelpCenter"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_56"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:layout_gravity="start|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/ic_as_contact" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:paddingStart="@dimen/dp_44"
                    android:paddingEnd="@dimen/dp_32"
                    android:text="@string/help_center"
                    android:textColor="@color/C_374151"
                    android:textSize="@dimen/sp_16" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/dp_24"
                    android:layout_height="@dimen/dp_24"
                    android:layout_gravity="end|center_vertical"
                    android:contentDescription="@null"
                    android:src="@mipmap/mine_right" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
