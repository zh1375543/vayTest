<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@mipmap/ic_page_bg"
    android:layout_height="match_parent">

    <com.vaycore.finance.ui.views.PageHeaderView
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:centerText="@string/loan_application"
        app:layout_constraintTop_toTopOf="parent" />

    <com.vaycore.finance.ui.views.ContentStateLayout
        android:id="@+id/loading_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/tvPrivacy"
        app:layout_constraintTop_toBottomOf="@id/titleBar">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/dp_16">

                <com.vaycore.finance.ui.views.StyledTextView
                    android:id="@+id/tvAbout"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp_48"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:layout_marginTop="@dimen/dp_12"
                    android:drawableEnd="@mipmap/mine_right"
                    android:drawablePadding="@dimen/dp_8"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/dp_20"
                    android:paddingEnd="@dimen/dp_16"
                    android:text="@string/about_lease"
                    android:textColor="@color/color_7087F8"
                    android:textSize="@dimen/sp_15"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:radius="@dimen/dp_16"
                    app:solidColor="@color/white" />

                <com.vaycore.finance.ui.views.LoanProductSummaryView
                    android:id="@+id/productSummaryView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:layout_marginTop="@dimen/dp_10"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvAbout" />

                <com.vaycore.finance.ui.views.SingleProductDetailView
                    android:id="@+id/detailView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:layout_marginTop="@dimen/dp_12"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/productSummaryView" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </com.vaycore.finance.ui.views.ContentStateLayout>

    <TextView
        android:id="@+id/tvPrivacy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_12"
        android:gravity="center"
        android:lineSpacingExtra="@dimen/dp_4"
        android:paddingHorizontal="@dimen/dp_36"
        android:paddingTop="@dimen/dp_15"
        android:paddingBottom="@dimen/dp_6"
        android:text="@string/product_detail_agreement"
        android:textColor="@color/C_6D7280"
        android:textSize="@dimen/sp_13"
        app:layout_constraintBottom_toTopOf="@id/bottomCard"
        app:layout_goneMarginBottom="@dimen/dp_30" />

    <com.vaycore.finance.ui.views.StyledConstraintLayout
        android:id="@+id/bottomCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_16"
        android:layout_marginBottom="@dimen/dp_10"
        android:paddingTop="@dimen/dp_4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:radius="@dimen/dp_30"
        app:solidColor="@color/C_F6F6F6"
        app:strokeColor="@color/white"
        app:strokeWidth="@dimen/dp_1">

        <TextView
            android:id="@+id/tvAccountTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_20"
            android:text="@string/account_receivable"
            android:textColor="@color/C_9CA3AF"
            android:textSize="@dimen/sp_14"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/accountInfoLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp_8"
            android:gravity="end"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/tvAccountTitle"
            app:layout_constraintEnd_toStartOf="@id/tvChange"
            app:layout_constraintTop_toTopOf="@id/tvAccountTitle">

            <TextView
                android:id="@+id/tvAccountType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:textColor="@color/C_111827"
                android:textSize="@dimen/sp_12"
                android:textStyle="bold"
                tools:text="card" />

            <TextView
                android:id="@+id/tvCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:textColor="@color/C_111827"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold"
                tools:text="111111" />
        </androidx.appcompat.widget.LinearLayoutCompat>

        <com.vaycore.finance.ui.views.StyledTextView
            android:id="@+id/tvChange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp_20"
            android:gravity="center"
            android:paddingHorizontal="@dimen/dp_12"
            android:paddingVertical="@dimen/dp_8"
            android:text="@string/change"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_14"
            app:layout_constraintBottom_toBottomOf="@id/tvAccountTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvAccountTitle"
            app:radius="@dimen/dp_15"
            app:solidColor="@color/color_7087F8" />

        <com.vaycore.finance.ui.views.StyledConstraintLayout
            android:id="@+id/loanTipLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_16"
            android:layout_marginTop="@dimen/dp_16"
            android:paddingHorizontal="@dimen/dp_16"
            android:paddingVertical="@dimen/dp_14"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAccountTitle"
            app:radius="@dimen/dp_16"
            app:solidColor="@color/white">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivLoanTip"
                android:layout_width="@dimen/dp_32"
                android:layout_height="@dimen/dp_32"
                android:src="@mipmap/ic_loan_tip"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvLoanTip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_12"
                android:lineSpacingExtra="@dimen/dp_2"
                android:text="@string/loan_account_tip"
                android:textColor="@color/C_9CA3AF"
                android:textSize="@dimen/sp_14"
                app:layout_constraintBottom_toBottomOf="@id/ivLoanTip"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivLoanTip"
                app:layout_constraintTop_toTopOf="@id/ivLoanTip" />
        </com.vaycore.finance.ui.views.StyledConstraintLayout>

        <com.vaycore.finance.ui.views.StyledConstraintLayout
            android:id="@+id/repaymentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_10"
            android:paddingTop="@dimen/dp_16"
            android:paddingBottom="@dimen/dp_20"
            app:layout_constraintTop_toBottomOf="@id/loanTipLayout"
            app:radius="@dimen/dp_30"
            app:solidColor="@color/white">


            <com.vaycore.finance.ui.widget.ActionButtonView
                android:id="@+id/btnApply"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp_48"
                android:layout_marginHorizontal="@dimen/dp_20"
                android:layout_marginTop="@dimen/dp_16"
                android:text="@string/withdrawal"
                android:textSize="@dimen/sp_18"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvLoanTip" />
        </com.vaycore.finance.ui.views.StyledConstraintLayout>
    </com.vaycore.finance.ui.views.StyledConstraintLayout>

    <androidx.constraintlayout.widget.Group
        android:id="@+id/bottom_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="tvPrivacy,bottomCard"
        tools:visibility="visible" />
</androidx.constraintlayout.widget.ConstraintLayout>
