<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:background="@color/C_FEF8ED">

    <com.vaycore.finance.ui.views.StyledConstraintLayout
        android:id="@+id/top_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/dp_16"
        android:paddingBottom="@dimen/dp_16"
        app:layout_constraintTop_toTopOf="parent"
        app:radius="@dimen/dp_12"
        app:solidColor="@color/white">

        <com.vaycore.finance.ui.views.StyledConstraintLayout
            android:id="@+id/detail_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/dp_16"
            app:layout_constraintTop_toTopOf="parent"
            app:solidColor="@color/transparent">

            <androidx.constraintlayout.widget.Group
                android:id="@+id/installGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:constraint_referenced_ids="tvInstallFeeTitle,tvInstallFee" />

            <TextView
                android:id="@+id/tvDaysTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/dp_15"
                android:text="@string/loan_period_days"
                android:textColor="@color/C_6D7280"
                android:textSize="@dimen/sp_13"
                app:layout_constraintBottom_toBottomOf="@id/tvDays"
                app:layout_constraintEnd_toStartOf="@id/tvDays"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvDays" />

            <TextView
                android:id="@+id/tvDays"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/C_374151"
                android:textSize="@dimen/sp_14"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="91 Days" />

            <TextView
                android:id="@+id/tvActuallyTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginEnd="@dimen/dp_15"
                android:text="@string/actually_amount"
                android:textColor="@color/C_6D7280"
                android:textSize="@dimen/sp_13"
                app:layout_constraintBottom_toBottomOf="@id/tvActuallyAmount"
                app:layout_constraintEnd_toStartOf="@id/tvActuallyAmount"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvDaysTitle" />

            <TextView
                android:id="@+id/tvActuallyAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/C_374151"
                android:textSize="@dimen/sp_14"
                app:layout_constraintEnd_toEndOf="@id/tvDays"
                app:layout_constraintTop_toTopOf="@id/tvActuallyTitle"
                tools:text="19,991,000" />

            <TextView
                android:id="@+id/tvInterestTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginEnd="@dimen/dp_15"
                android:text="@string/interest_day"
                android:textColor="@color/C_6D7280"
                android:textSize="@dimen/sp_13"
                app:layout_constraintBottom_toBottomOf="@id/tvInterest"
                app:layout_constraintEnd_toStartOf="@id/tvInterest"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvActuallyTitle" />

            <TextView
                android:id="@+id/tvInterest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/C_374151"
                android:textSize="@dimen/sp_14"
                app:layout_constraintEnd_toEndOf="@id/tvActuallyAmount"
                app:layout_constraintTop_toTopOf="@id/tvInterestTitle"
                tools:text="9,000" />

            <TextView
                android:id="@+id/tvDateTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginEnd="@dimen/dp_15"
                android:text="@string/due_date"
                android:textColor="@color/C_6D7280"
                android:textSize="@dimen/sp_13"
                app:layout_constraintBottom_toBottomOf="@id/tvDate"
                app:layout_constraintEnd_toStartOf="@id/tvDate"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvInterestTitle" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/C_374151"
                android:textSize="@dimen/sp_14"
                app:layout_constraintEnd_toEndOf="@id/tvInterest"
                app:layout_constraintTop_toTopOf="@id/tvDateTitle"
                tools:text="25/12/2025" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_8"
                android:orientation="vertical"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/tvDateTitle"
                tools:itemCount="2"
                tools:listitem="@layout/item_product_fee" />

            <TextView
                android:id="@+id/tvInstallFeeTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginEnd="@dimen/dp_15"
                android:text="@string/install_fee"
                android:textColor="@color/C_6D7280"
                android:textSize="@dimen/sp_13"
                app:layout_constraintBottom_toBottomOf="@id/tvInstallFee"
                app:layout_constraintEnd_toStartOf="@id/tvInstallFee"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rvFee" />

            <TextView
                android:id="@+id/tvInstallFee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/C_374151"
                android:textSize="@dimen/sp_14"
                app:layout_constraintEnd_toEndOf="@id/tvDate"
                app:layout_constraintTop_toTopOf="@id/tvInstallFeeTitle"
                tools:text="0" />

            <TextView
                android:id="@+id/tvModelTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginEnd="@dimen/dp_15"
                android:text="@string/phone_model"
                android:textColor="@color/C_6D7280"
                android:textSize="@dimen/sp_13"
                app:layout_constraintBottom_toBottomOf="@id/tvModel"
                app:layout_constraintEnd_toStartOf="@id/tvModel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvInstallFeeTitle" />

            <TextView
                android:id="@+id/tvModel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/C_374151"
                android:textSize="@dimen/sp_14"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/tvDate"
                app:layout_constraintTop_toTopOf="@id/tvModelTitle"
                tools:text="xiaomi15" />
        </com.vaycore.finance.ui.views.StyledConstraintLayout>

        <View
            android:id="@+id/planDivider"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_0_5"
            android:layout_marginHorizontal="@dimen/dp_32"
            android:layout_marginTop="@dimen/dp_14"
            android:alpha="0.55"
            android:background="@color/C_D2D5DA"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/detail_layout" />

        <TextView
            android:id="@+id/tvPlan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_36"
            android:layout_marginTop="@dimen/dp_10"
            android:gravity="center"
            android:lineSpacingExtra="@dimen/dp_1"
            android:text="@string/plan_desc"
            android:textColor="@color/C_374151"
            android:textSize="@dimen/sp_16"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/planDivider" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivArrowPlan"
            android:layout_width="@dimen/dp_26"
            android:layout_height="@dimen/dp_26"
            android:layout_marginTop="@dimen/dp_8"
            android:padding="@dimen/dp_5"
            android:src="@mipmap/ic_arrow_down"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPlan" />

        <androidx.constraintlayout.widget.Group
            android:id="@+id/planGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="planDivider,tvPlan,ivArrowPlan" />

        <com.vaycore.finance.ui.views.StyledConstraintLayout
            android:id="@+id/plan_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/dp_16"
            android:paddingBottom="@dimen/dp_2"
            android:visibility="visible"
            app:layout_constraintTop_toBottomOf="@id/ivArrowPlan"
            app:solidColor="@color/transparent"
            tools:visibility="visible">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_26"
                android:orientation="horizontal"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toTopOf="parent"
                tools:listitem="@layout/product_repayment_menu_adapter" />

            <TextView
                android:id="@+id/tvInstallDetail"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp_22"
                android:layout_marginTop="@dimen/dp_14"
                android:gravity="center_vertical"
                android:text="@string/installment_details"
                android:textColor="@color/C_111827"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/ivMorePlan"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rvPlan" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivMorePlan"
                android:layout_width="@dimen/dp_22"
                android:layout_height="@dimen/dp_22"
                android:src="@mipmap/product_bottom"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvInstallDetail"
                app:tint="@color/C_374151" />

            <com.vaycore.finance.ui.views.StyledTextView
                android:id="@+id/bg"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/dp_m_10"
                app:layout_constraintBottom_toBottomOf="@id/rvRepayment"
                app:layout_constraintTop_toTopOf="@id/tvDueDateTitle"
                app:radius="@dimen/dp_12"
                app:solidColor="@color/C_F8F7F3" />

            <TextView
                android:id="@+id/tvDueDateTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_20"
                android:paddingStart="@dimen/dp_10"
                android:text="@string/due_date"
                android:textColor="@color/C_6D7280"
                android:textSize="@dimen/sp_14"
                app:layout_constraintEnd_toStartOf="@id/tvRepaymentAmountTitle"
                app:layout_constraintHorizontal_weight="2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvInstallDetail" />

            <TextView
                android:id="@+id/tvRepaymentAmountTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:paddingEnd="@dimen/dp_10"
                android:text="@string/repayment_amount"
                android:textColor="@color/C_6D7280"
                android:textSize="@dimen/sp_14"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="3"
                app:layout_constraintStart_toEndOf="@id/tvDueDateTitle"
                app:layout_constraintTop_toTopOf="@id/tvDueDateTitle" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRepayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/tvDueDateTitle"
                tools:itemCount="2"
                tools:listitem="@layout/product_installment_adapter" />

            <androidx.constraintlayout.widget.Group
                android:id="@+id/repaymentGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="visible"
                app:constraint_referenced_ids="tvDueDateTitle,tvRepaymentAmountTitle,rvRepayment,bg" />
        </com.vaycore.finance.ui.views.StyledConstraintLayout>
    </com.vaycore.finance.ui.views.StyledConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
