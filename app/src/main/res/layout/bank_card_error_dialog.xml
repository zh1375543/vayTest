<?xml version="1.0" encoding="utf-8"?>
<com.vaycore.finance.ui.views.StyledConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="@dimen/dp_30"
    app:radius="@dimen/dp_12"
    app:solidColor="@color/white">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_title"
        android:layout_width="@dimen/dp_0"
        android:src="@mipmap/ic_bank_error"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_36"
        android:layout_marginTop="@dimen/dp_24"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tvDesc"
        android:layout_width="@dimen/dp_0"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_40"
        android:layout_marginTop="@dimen/dp_12"
        android:gravity="center"
        android:lineSpacingExtra="@dimen/dp_2"
        android:textColor="@color/C_374151"
        android:textSize="@dimen/sp_16"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_title"
        app:layout_goneMarginTop="@dimen/dp_58"
        tools:text="Your last order failed due to incorrect bankcard information. Please modify your bankcard and resubmit the order." />

    <com.vaycore.finance.ui.widget.ActionButtonView
        android:id="@+id/btnClose"
        android:layout_width="0dp"
        android:layout_height="@dimen/dp_44"
        android:layout_marginStart="@dimen/dp_16"
        android:layout_marginTop="@dimen/dp_30"
        android:text="@string/closed"
        android:textSize="@dimen/sp_14"
        android:textStyle="bold"
        app:buttonSolidColor="@color/C_F6F6F6"
        app:buttonTextColor="@color/color_7087F8"
        app:layout_constraintEnd_toStartOf="@id/btnSure"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDesc" />

    <com.vaycore.finance.ui.widget.ActionButtonView
        android:id="@+id/btnSure"
        android:layout_width="0dp"
        android:layout_height="@dimen/dp_44"
        android:layout_marginStart="@dimen/dp_12"
        android:layout_marginEnd="@dimen/dp_16"
        android:gravity="center"
        android:text="@string/sure"
        android:textSize="@dimen/sp_14"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnClose"
        app:layout_constraintTop_toTopOf="@id/btnClose" />
</com.vaycore.finance.ui.views.StyledConstraintLayout>
