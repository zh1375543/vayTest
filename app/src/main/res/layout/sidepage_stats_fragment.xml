<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:paddingStart="@dimen/dp_16"
    android:paddingEnd="@dimen/dp_16"
    android:paddingBottom="@dimen/dp_28">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.vaycore.finance.ui.views.StyledConstraintLayout
            android:id="@+id/reportCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_12"
            android:paddingStart="@dimen/dp_24"
            android:paddingTop="@dimen/dp_14"
            android:paddingEnd="@dimen/dp_24"
            android:paddingBottom="@dimen/dp_24"
            app:radius="@dimen/dp_24"
            app:solidColor="@color/white">

            <TextView
                android:id="@+id/tvLoanAmountLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/portal_loan_amount"
                android:textColor="@color/C_374151"
                android:textSize="@dimen/sp_16"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ivMoney"
                android:layout_width="@dimen/dp_80"
                android:layout_height="@dimen/dp_70"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@mipmap/ic_home_money_img"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvLoanAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_24"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/C_111827"
                android:textSize="@dimen/sp_28"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/ivMoney"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvLoanAmountLabel"
                tools:text="200,000,000đ" />

            <TextView
                android:id="@+id/tvSavedThisMonthLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_30"
                android:text="@string/portal_saved_this_month"
                android:textColor="@color/C_6D7280"
                android:textSize="@dimen/sp_14"
                app:layout_constraintEnd_toStartOf="@id/tvSavedThisMonth"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvLoanAmount" />

            <TextView
                android:id="@+id/tvSavedThisMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/C_374151"
                android:textSize="@dimen/sp_14"
                android:textStyle="bold"
                app:layout_constraintBaseline_toBaselineOf="@id/tvSavedThisMonthLabel"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="20,000,000đ" />

            <TextView
                android:id="@+id/tvTotalSavingsLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_16"
                android:text="@string/portal_total_savings"
                android:textColor="@color/C_6D7280"
                android:textSize="@dimen/sp_14"
                app:layout_constraintEnd_toStartOf="@id/tvTotalSavings"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSavedThisMonthLabel" />

            <TextView
                android:id="@+id/tvTotalSavings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/C_374151"
                android:textSize="@dimen/sp_14"
                android:textStyle="bold"
                app:layout_constraintBaseline_toBaselineOf="@id/tvTotalSavingsLabel"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="0 Day" />

        </com.vaycore.finance.ui.views.StyledConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/metricsGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_15">

            <include
                android:id="@+id/totalPlansCard"
                layout="@layout/item_savings_report_metric"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp_80"
                android:layout_marginEnd="@dimen/dp_8"
                app:layout_constraintEnd_toStartOf="@id/activePlansCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <include
                android:id="@+id/activePlansCard"
                layout="@layout/item_savings_report_metric"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp_80"
                android:layout_marginStart="@dimen/dp_8"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/totalPlansCard"
                app:layout_constraintTop_toTopOf="parent" />

            <include
                android:id="@+id/completedPlansCard"
                layout="@layout/item_savings_report_metric"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp_80"
                android:layout_marginTop="@dimen/dp_16"
                android:layout_marginEnd="@dimen/dp_8"
                app:layout_constraintEnd_toStartOf="@id/averageSavingsCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/totalPlansCard" />

            <include
                android:id="@+id/averageSavingsCard"
                layout="@layout/item_savings_report_metric"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp_80"
                android:layout_marginStart="@dimen/dp_8"
                android:layout_marginTop="@dimen/dp_16"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/completedPlansCard"
                app:layout_constraintTop_toBottomOf="@id/activePlansCard" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tvSavingsLevelTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_32"
            android:gravity="center"
            android:text="@string/portal_savings_level"
            android:textColor="@color/C_111827"
            android:textSize="@dimen/sp_20"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivSavingsLevel"
            android:layout_width="@dimen/dp_180"
            android:layout_height="@dimen/dp_180"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/dp_20"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:src="@mipmap/ic_as_level" />

        <TextView
            android:id="@+id/tvLevelDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_20"
            android:gravity="center"
            android:text="@string/portal_savings_level_desc"
            android:textColor="@color/C_6D7280"
            android:textSize="@dimen/sp_12" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
