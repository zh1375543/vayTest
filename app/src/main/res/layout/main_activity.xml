<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:background="@mipmap/ic_page_bg"
    android:layout_height="match_parent">

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_56"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent" />

    <View
        android:id="@+id/vHome"
        android:layout_width="0dp"
        android:layout_height="@dimen/dp_56"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/vOrder"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/vOrder"
        android:layout_width="0dp"
        android:layout_height="@dimen/dp_56"
        app:layout_constraintEnd_toStartOf="@id/vMine"
        app:layout_constraintStart_toEndOf="@id/vHome"
        app:layout_constraintTop_toTopOf="@id/vHome" />

    <View
        android:id="@+id/vMine"
        android:layout_width="0dp"
        android:layout_height="@dimen/dp_56"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/vOrder"
        app:layout_constraintTop_toTopOf="@id/vHome" />

    <com.vaycore.finance.ui.views.StyledTextView
        android:id="@+id/tvHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:drawableTop="@mipmap/tab_home_normal"
        android:text="@string/home"
        android:gravity="center"
        android:textColor="@color/C_9CA3AF"
        android:textSize="@dimen/sp_12"
        app:drawableTopSelected="@mipmap/tab_home_select"
        app:layout_constraintBottom_toBottomOf="@id/vHome"
        app:layout_constraintEnd_toEndOf="@id/vHome"
        app:layout_constraintStart_toStartOf="@id/vHome"
        app:layout_constraintTop_toTopOf="@id/vHome"
        app:textColorSelected="@color/C_111827" />

    <com.vaycore.finance.ui.views.StyledTextView
        android:id="@+id/tvOrder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableTop="@mipmap/tab_order_normal"
        android:text="@string/order"
        android:textColor="@color/C_9CA3AF"
        android:textSize="@dimen/sp_12"
        android:gravity="center"
        app:drawableTopSelected="@mipmap/tab_order_select"
        app:layout_constraintBottom_toBottomOf="@id/vOrder"
        app:layout_constraintEnd_toEndOf="@id/vOrder"
        app:layout_constraintStart_toStartOf="@id/vOrder"
        app:layout_constraintTop_toTopOf="@id/vOrder"
        app:textColorSelected="@color/C_111827" />

    <com.vaycore.finance.ui.views.StyledTextView
        android:id="@+id/tvMine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableTop="@mipmap/tab_mine_normal"
        android:text="@string/mine"
        android:textColor="@color/C_9CA3AF"
        android:textSize="@dimen/sp_12"
        android:gravity="center"
        app:drawableTopSelected="@mipmap/tab_mine_select"
        app:layout_constraintBottom_toBottomOf="@id/vMine"
        app:layout_constraintEnd_toEndOf="@id/vMine"
        app:layout_constraintStart_toStartOf="@id/vMine"
        app:layout_constraintTop_toTopOf="@id/vMine"
        app:textColorSelected="@color/C_111827" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivMsg"
        android:layout_width="@dimen/dp_30"
        android:layout_height="@dimen/dp_30"
        android:padding="@dimen/sp_5"
        android:layout_marginEnd="@dimen/dp_24"
        android:layout_marginStart="@dimen/dp_10"
        android:background="@drawable/bg_header_back"
        android:src="@mipmap/image_notify"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivCustomer"
        android:layout_width="@dimen/dp_30"
        android:layout_height="@dimen/dp_30"
        android:src="@mipmap/image_contact"
        android:padding="@dimen/sp_5"
        android:layout_marginEnd="@dimen/dp_10"
        android:background="@drawable/bg_header_back"
        app:layout_constraintBottom_toBottomOf="@id/ivMsg"
        app:layout_constraintEnd_toStartOf="@id/ivMsg"
        app:layout_constraintTop_toTopOf="@id/ivMsg" />

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="0dp"
        android:layout_height="@dimen/dp_44"
        android:layout_marginStart="@dimen/dp_24"
        android:layout_marginEnd="@dimen/dp_8"
        android:gravity="center_vertical"
        android:text="@string/app_name"
        android:textColor="@color/C_111827"
        android:textSize="@dimen/sp_20"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/ivCustomer"
        app:layout_constraintEnd_toStartOf="@id/ivCustomer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivCustomer" />

    <androidx.constraintlayout.widget.Group
        android:id="@+id/topGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="ivCustomer,ivMsg,tvAppName" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vpMain"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/vHome"
        app:layout_constraintTop_toBottomOf="@id/ivCustomer" />

</androidx.constraintlayout.widget.ConstraintLayout>
