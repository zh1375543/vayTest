<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.vaycore.finance.ui.views.ContentStateLayout
        android:id="@+id/loading_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.vaycore.finance.ui.views.StyledConstraintLayout
                android:id="@+id/noticeLayout"
                style="@style/NoticeBar"
                android:layout_width="@dimen/dp_0"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_24"
                android:layout_marginTop="@dimen/dp_12"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.vaycore.finance.ui.widget.RollingNoticeView
                    android:id="@+id/marqueeView"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </com.vaycore.finance.ui.views.StyledConstraintLayout>

            <com.vaycore.finance.ui.widget.TicketBackgroundLayout
                android:id="@+id/repayment_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_20"
                android:layout_marginTop="@dimen/dp_14"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/dp_18"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/noticeLayout"
                app:ticketColor="@color/color_7087F8"
                app:ticketCornerRadius="@dimen/dp_16"
                app:ticketSideCutoutCenterFromBottom="@dimen/dp_61"
                app:ticketSideCutoutRadius="@dimen/dp_16"
                tools:visibility="gone">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivOrderContentHead"
                    android:layout_width="@dimen/dp_68"
                    android:layout_height="@dimen/dp_68"
                    android:layout_marginTop="@dimen/dp_8"
                    android:src="@mipmap/ic_order_content_head"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvOrderNum"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dp_28"
                    android:layout_marginTop="@dimen/dp_4"
                    android:gravity="center"
                    android:text="@string/home_order_num"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_15"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ivOrderContentHead" />

                <com.vaycore.finance.ui.views.StyledTextView
                    android:id="@+id/tvRepaymentTip"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp_52"
                    android:layout_marginHorizontal="@dimen/dp_28"
                    android:layout_marginTop="@dimen/dp_16"
                    android:gravity="center"
                    android:paddingHorizontal="@dimen/dp_16"
                    android:text="@string/batch_repayment_tips"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_13"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvOrderNum"
                    app:radius="@dimen/dp_8"
                    app:solidColor="@color/color_33ffff"
                    app:strokeColor="@color/white"
                    app:strokeWidth="@dimen/dp_1" />

                <com.vaycore.finance.ui.widget.ActionButtonView
                    android:id="@+id/tvRepayment"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_48"
                    android:layout_marginHorizontal="@dimen/dp_36"
                    android:layout_marginTop="@dimen/dp_10"
                    android:paddingHorizontal="@dimen/dp_22"
                    android:text="@string/batch_repayment"
                    android:textSize="@dimen/sp_18"
                    android:textStyle="bold"
                    app:buttonSolidColor="@color/C_89F5C7"
                    app:buttonTextColor="@color/black"
                    app:layout_constraintTop_toBottomOf="@id/tvRepaymentTip" />
            </com.vaycore.finance.ui.widget.TicketBackgroundLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/order_layout"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/dp_18"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/repayment_layout">

                <TextView
                    android:id="@+id/tvOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/orders"
                    android:textColor="@color/C_111827"
                    android:textSize="@dimen/sp_18"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvOrder"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:layout_marginTop="@dimen/dp_6"
                    android:orientation="vertical"
                    android:overScrollMode="never"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvOrders"
                    tools:itemCount="4"
                    tools:listitem="@layout/home_order_adapter"
                    tools:visibility="visible" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/emptyOrder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/dp_24"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/noticeLayout">

                <com.vaycore.finance.ui.views.StyledConstraintLayout
                    android:id="@+id/emptyOrderBg"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_212"
                    android:layout_marginHorizontal="@dimen/dp_24"
                    android:layout_marginTop="@dimen/dp_14"
                    app:radius="@dimen/dp_24"
                    app:solidColor="@color/white">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivEmptyOrder"
                        android:layout_width="@dimen/dp_80"
                        android:layout_height="@dimen/dp_80"
                        android:layout_marginTop="@dimen/dp_40"
                        android:src="@mipmap/ic_tab_order_null"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_12"
                        android:gravity="center"
                        android:text="@string/empty_home_order"
                        android:textColor="@color/C_6D7280"
                        android:textSize="@dimen/sp_14"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ivEmptyOrder" />

                </com.vaycore.finance.ui.views.StyledConstraintLayout>

                <TextView
                    android:id="@+id/tvBenefits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dp_24"
                    android:layout_marginTop="@dimen/dp_20"
                    android:gravity="center"
                    android:text="@string/benefits_of_paying"
                    android:textColor="@color/C_111827"
                    android:textSize="@dimen/sp_18"
                    android:textStyle="bold" />

                <com.vaycore.finance.ui.views.StyledConstraintLayout
                    android:id="@+id/tip_layout1"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_80"
                    android:layout_marginHorizontal="@dimen/dp_24"
                    android:layout_marginTop="@dimen/dp_16"
                    android:paddingHorizontal="@dimen/dp_20"
                    app:radius="@dimen/dp_24"
                    app:solidColor="@color/white">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivTip1"
                        android:layout_width="@dimen/dp_48"
                        android:layout_height="@dimen/dp_48"
                        android:src="@mipmap/ic_tab_order_credit"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvTitle1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/home_order_title1"
                        android:textColor="@color/C_111827"
                        android:textSize="@dimen/sp_14"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/tvDesc1"
                        app:layout_constraintEnd_toStartOf="@id/ivTip1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tvDesc1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_2"
                        android:lineSpacingExtra="@dimen/dp_1"
                        android:text="@string/home_order_desc1"
                        android:textColor="@color/C_6D7280"
                        android:textSize="@dimen/sp_12"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="@id/tvTitle1"
                        app:layout_constraintStart_toStartOf="@id/tvTitle1"
                        app:layout_constraintTop_toBottomOf="@id/tvTitle1" />
                </com.vaycore.finance.ui.views.StyledConstraintLayout>

                <com.vaycore.finance.ui.views.StyledConstraintLayout
                    android:id="@+id/tip_layout2"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_80"
                    android:layout_marginHorizontal="@dimen/dp_24"
                    android:layout_marginTop="@dimen/dp_12"
                    android:paddingHorizontal="@dimen/dp_20"
                    app:radius="@dimen/dp_24"
                    app:solidColor="@color/white">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivTip2"
                        android:layout_width="@dimen/dp_48"
                        android:layout_height="@dimen/dp_48"
                        android:src="@mipmap/ic_tab_order_increase"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvTitle2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_12"
                        android:gravity="end"
                        android:text="@string/home_order_title2"
                        android:textColor="@color/C_111827"
                        android:textSize="@dimen/sp_14"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/tvDesc2"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivTip2"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tvDesc2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_2"
                        android:gravity="end"
                        android:lineSpacingExtra="@dimen/dp_1"
                        android:text="@string/home_order_desc2"
                        android:textColor="@color/C_6D7280"
                        android:textSize="@dimen/sp_12"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="@id/tvTitle2"
                        app:layout_constraintStart_toStartOf="@id/tvTitle2"
                        app:layout_constraintTop_toBottomOf="@id/tvTitle2" />
                </com.vaycore.finance.ui.views.StyledConstraintLayout>

                <com.vaycore.finance.ui.views.StyledConstraintLayout
                    android:id="@+id/tip_layout3"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_80"
                    android:layout_marginHorizontal="@dimen/dp_24"
                    android:layout_marginTop="@dimen/dp_12"
                    android:paddingHorizontal="@dimen/dp_20"
                    app:radius="@dimen/dp_24"
                    app:solidColor="@color/white">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivTip3"
                        android:layout_width="@dimen/dp_48"
                        android:layout_height="@dimen/dp_48"
                        android:src="@mipmap/ic_tab_order_improve"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvTitle3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/home_order_title3"
                        android:textColor="@color/C_111827"
                        android:textSize="@dimen/sp_14"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/tvDesc3"
                        app:layout_constraintEnd_toStartOf="@id/ivTip3"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tvDesc3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_2"
                        android:lineSpacingExtra="@dimen/dp_1"
                        android:text="@string/home_order_desc3"
                        android:textColor="@color/C_6D7280"
                        android:textSize="@dimen/sp_12"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="@id/tvTitle3"
                        app:layout_constraintStart_toStartOf="@id/tvTitle3"
                        app:layout_constraintTop_toBottomOf="@id/tvTitle3" />
                </com.vaycore.finance.ui.views.StyledConstraintLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.vaycore.finance.ui.views.ContentStateLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
