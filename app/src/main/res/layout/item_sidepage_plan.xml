<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="@dimen/dp_16">

    <com.vaycore.finance.ui.views.StyledConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/dp_24"
        app:radius="@dimen/dp_24"
        app:solidColor="@color/white">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivPlanIcon"
            android:layout_width="@dimen/dp_36"
            android:layout_height="@dimen/dp_36"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:src="@mipmap/ic_product_defalut_img"
            app:shapeAppearanceOverlay="@style/Round_Circle" />

        <TextView
            android:id="@+id/tvPlanName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_12"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/C_111827"
            android:textSize="@dimen/sp_16"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btSaveMoney"
            app:layout_constraintStart_toEndOf="@id/ivPlanIcon"
            app:layout_constraintTop_toTopOf="@id/ivPlanIcon"
            tools:text="XXXX Savings Plan" />

        <TextView
            android:id="@+id/tvDaysLeft"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_12"
            android:layout_marginTop="@dimen/dp_2"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/C_9CA3AF"
            android:textSize="@dimen/sp_12"
            app:layout_constraintEnd_toStartOf="@id/btSaveMoney"
            app:layout_constraintStart_toEndOf="@id/ivPlanIcon"
            app:layout_constraintTop_toBottomOf="@id/tvPlanName"
            tools:text="372 days left" />

        <com.vaycore.finance.ui.widget.ActionButtonView
            android:id="@+id/btSaveMoney"
            android:layout_width="@dimen/dp_112"
            android:layout_height="@dimen/dp_42"
            android:layout_marginStart="@dimen/dp_8"
            android:text="@string/portal_save_money"
            android:textSize="@dimen/sp_13"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ProgressBar
            android:id="@+id/progressPlan"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_12"
            android:layout_marginTop="@dimen/dp_18"
            android:max="10000"
            android:progress="0"
            android:progressDrawable="@drawable/bg_sidepage_plan_progress"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivPlanIcon"
            tools:progress="35" />

        <TextView
            android:id="@+id/tvSavedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_14"
            android:text="@string/portal_saved"
            android:textColor="@color/C_9CA3AF"
            android:textSize="@dimen/sp_11"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressPlan" />

        <TextView
            android:id="@+id/tvGoalLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="@string/portal_goal"
            android:textColor="@color/C_9CA3AF"
            android:textSize="@dimen/sp_11"
            app:layout_constraintBaseline_toBaselineOf="@id/tvSavedLabel"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSavedAmount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_5"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/color_7087F8"
            android:textSize="@dimen/sp_14"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tvGoalAmount"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSavedLabel"
            tools:text="₱20,000,000" />

        <TextView
            android:id="@+id/tvGoalAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_12"
            android:gravity="end"
            android:maxLines="1"
            android:textColor="@color/C_111827"
            android:textSize="@dimen/sp_14"
            android:textStyle="bold"
            app:layout_constraintBaseline_toBaselineOf="@id/tvSavedAmount"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="₱20,000,000" />

        <TextView
            android:id="@+id/tvNextSavingLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_18"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/portal_next_planned_saving_time"
            android:textColor="@color/C_9CA3AF"
            android:textSize="@dimen/sp_11"
            app:layout_constraintEnd_toStartOf="@id/tvNextSavingTime"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSavedAmount" />

        <TextView
            android:id="@+id/tvNextSavingTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_8"
            android:gravity="end"
            android:maxLines="1"
            android:textColor="@color/color_7087F8"
            android:textSize="@dimen/sp_11"
            app:layout_constraintBaseline_toBaselineOf="@id/tvNextSavingLabel"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Tomorrow" />

    </com.vaycore.finance.ui.views.StyledConstraintLayout>

</FrameLayout>
