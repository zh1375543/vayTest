<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@mipmap/ic_page_bg">

    <com.vaycore.finance.ui.views.PageHeaderView
        android:id="@+id/titleBar"
        android:layout_width="0dp"
        android:layout_height="@dimen/dp_56"
        app:fitStatusBar="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.vaycore.finance.ui.views.ContentStateLayout
        android:id="@+id/loadingLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleBar">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:paddingStart="@dimen/dp_16"
            android:paddingTop="@dimen/dp_12"
            android:paddingEnd="@dimen/dp_16"
            android:paddingBottom="@dimen/dp_24">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.vaycore.finance.ui.views.StyledConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/dp_20"
                    app:radius="@dimen/dp_24"
                    app:solidColor="@color/white">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivPlanIcon"
                        android:layout_width="@dimen/dp_36"
                        android:layout_height="@dimen/dp_36"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        android:src="@mipmap/ic_product_defalut_img"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearanceOverlay="@style/Round_Circle" />

                    <TextView
                        android:id="@+id/tvPlanName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_12"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/C_111827"
                        android:textSize="@dimen/sp_14"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/ivPlanIcon"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivPlanIcon"
                        app:layout_constraintTop_toTopOf="@id/ivPlanIcon" />

                    <com.vaycore.finance.ui.views.StyledConstraintLayout
                        android:id="@+id/amountContainer"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/dp_48"
                        android:layout_marginTop="@dimen/dp_16"
                        android:paddingStart="@dimen/dp_14"
                        android:paddingEnd="@dimen/dp_14"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ivPlanIcon"
                        app:radius="@dimen/dp_24"
                        app:solidColor="@color/C_F6F6F6">

                        <TextView
                            android:id="@+id/tvAmountLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:textColor="@color/C_9CA3AF"
                            android:textSize="@dimen/sp_12"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/tvAmount"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/C_374151"
                            android:textSize="@dimen/sp_16"
                            android:textStyle="bold"
                            app:layout_constraintBaseline_toBaselineOf="@id/tvAmountLabel"
                            app:layout_constraintEnd_toEndOf="parent" />

                    </com.vaycore.finance.ui.views.StyledConstraintLayout>

                    <TextView
                        android:id="@+id/tvRecordTimeLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_18"
                        android:textColor="@color/C_9CA3AF"
                        android:textSize="@dimen/sp_12"
                        app:layout_constraintEnd_toStartOf="@id/tvRecordTime"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/amountContainer" />

                    <TextView
                        android:id="@+id/tvRecordTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_7087F8"
                        android:textSize="@dimen/sp_12"
                        app:layout_constraintBaseline_toBaselineOf="@id/tvRecordTimeLabel"
                        app:layout_constraintEnd_toEndOf="parent" />

                </com.vaycore.finance.ui.views.StyledConstraintLayout>

                <com.vaycore.finance.ui.views.StyledLinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_16"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/dp_10"
                    android:paddingTop="@dimen/dp_16"
                    android:paddingEnd="@dimen/dp_10"
                    android:paddingBottom="@dimen/dp_24"
                    app:radius="@dimen/dp_24"
                    app:solidColor="@color/white">

                    <com.vaycore.finance.ui.widget.FormItemView
                        android:id="@+id/savingAmountView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:formType="input"
                        app:hintText="@string/please_enter"
                        app:inputBackgroundColor="@color/C_F6F6F6"
                        app:inputType="number"
                        app:titleText="@string/portal_today_saving" />

                    <com.vaycore.finance.ui.widget.FormItemView
                        android:id="@+id/locationView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_10"
                        app:formEndIcon="@mipmap/ic_as_location"
                        app:formType="select"
                        app:hintText="@string/please_choose"
                        app:inputBackgroundColor="@color/C_F6F6F6"
                        app:inputType="text"
                        app:titleText="@string/portal_savings_location" />

                    <TextView
                        android:id="@+id/tvRecordPhotoLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_16"
                        android:layout_marginTop="@dimen/dp_12"
                        android:layout_marginEnd="@dimen/dp_16"
                        android:text="@string/portal_record_photo"
                        android:textColor="@color/C_374151"
                        android:textSize="@dimen/sp_14"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecordPhotos"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_88"
                        android:layout_marginStart="@dimen/dp_16"
                        android:layout_marginEnd="@dimen/dp_16"
                        android:layout_marginTop="@dimen/dp_10"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never" />

                    <com.vaycore.finance.ui.widget.FormItemView
                        android:id="@+id/notesView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_12"
                        app:formType="input"
                        app:hintText="@string/please_enter"
                        app:inputBackgroundColor="@color/C_F6F6F6"
                        app:inputType="text"
                        app:titleText="@string/portal_notes" />

                </com.vaycore.finance.ui.views.StyledLinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </com.vaycore.finance.ui.views.ContentStateLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
