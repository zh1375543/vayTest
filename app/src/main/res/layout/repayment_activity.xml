<?xml version="1.0" encoding="utf-8"?>
<com.vaycore.finance.ui.views.StyledConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/mainBg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.vaycore.finance.ui.views.PageHeaderView
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:centerText="@string/repayment"
        app:layout_constraintTop_toTopOf="parent" />

    <com.vaycore.finance.ui.views.ContentStateLayout
        android:id="@+id/loading_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.vaycore.finance.ui.widget.TicketBackgroundLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_124"
                        android:layout_marginHorizontal="@dimen/dp_16"
                        android:layout_marginTop="@dimen/dp_8"
                        android:paddingHorizontal="@dimen/dp_20"
                        android:paddingTop="@dimen/dp_14"
                        android:paddingBottom="@dimen/dp_16"
                        app:ticketColor="@color/color_7087F8"
                        app:ticketCornerRadius="@dimen/dp_14"
                        app:ticketSideCutoutCenterFromBottom="@dimen/dp_61"
                        app:ticketSideCutoutRadius="@dimen/dp_18">

                        <TextView
                            android:id="@+id/tvOrderNo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="start"
                            android:text="@string/order_no"
                            android:textColor="@color/white"
                            android:textSize="@dimen/sp_14"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/tvRepayAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_10"
                            android:text="@string/repayment_amount"
                            android:textColor="@color/white"
                            android:textSize="@dimen/sp_14"
                            android:textStyle="normal"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvOrderNo" />

                        <TextView
                            android:id="@+id/tvAmount"
                            android:layout_width="@dimen/dp_0"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_4"
                            android:gravity="center"
                            android:textColor="@color/white"
                            android:textSize="@dimen/sp_34"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvRepayAmount"
                            tools:text="50000" />

                    </com.vaycore.finance.ui.widget.TicketBackgroundLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginHorizontal="@dimen/dp_16"
                        android:layout_marginTop="@dimen/dp_10"
                        android:gravity="center"
                        android:text="@string/choose_repayment_method"
                        android:textColor="@color/C_111827"
                        android:textSize="@dimen/sp_18"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvBank"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/dp_16"
                        android:layout_marginTop="@dimen/dp_12"
                        android:orientation="vertical"
                        android:overScrollMode="never"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:itemCount="1"
                        tools:listitem="@layout/repayment_adapter" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_16"
                        android:layout_marginTop="@dimen/dp_4"
                        android:gravity="center"
                        android:text="@string/repayment_voucher"
                        android:textColor="@color/C_111827"
                        android:textSize="@dimen/sp_16"
                        android:textStyle="bold" />

                    <com.vaycore.finance.ui.views.StyledConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/dp_16"
                        android:layout_marginTop="@dimen/dp_10"
                        android:paddingBottom="@dimen/dp_20"
                        app:radius="@dimen/dp_12"
                        app:solidColor="@color/white">

                        <TextView
                            android:id="@+id/tvSelect"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="@dimen/dp_12"
                            android:layout_marginTop="@dimen/dp_12"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="@dimen/dp_15"
                            android:text="@string/please_select_repayment_account"
                            android:textColor="@color/black"
                            android:textSize="@dimen/sp_13"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/dp_12"
                            android:text="@string/choose"
                            android:textColor="@color/color_7087F8"
                            android:textSize="@dimen/sp_11"
                            app:layout_constraintBottom_toBottomOf="@id/tvSelect"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tvSelect" />

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="@dimen/dp_160"
                            android:layout_height="@dimen/dp_91"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="@dimen/dp_12"
                            android:background="@mipmap/img_repay_banner"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvSelect">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginHorizontal="@dimen/dp_16"
                                android:layout_marginBottom="@dimen/dp_26"
                                android:drawableTop="@mipmap/ic_upload_img"
                                android:gravity="center"
                                android:lineSpacingExtra="@dimen/dp_2"
                                android:text="@string/upload"
                                android:textColor="@color/C_374151"
                                android:textSize="@dimen/sp_12"
                                app:layout_constraintBottom_toBottomOf="parent" />

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/ivChoose"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.vaycore.finance.ui.views.StyledConstraintLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <com.vaycore.finance.ui.widget.ActionButtonView
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48"
                android:layout_marginHorizontal="@dimen/dp_34"
                android:layout_marginVertical="@dimen/dp_20"
                android:text="@string/submit"
                android:textSize="@dimen/sp_18"
                android:textStyle="bold" />

        </LinearLayout>
    </com.vaycore.finance.ui.views.ContentStateLayout>
</com.vaycore.finance.ui.views.StyledConstraintLayout>
