<?xml version="1.0" encoding="utf-8"?>
<com.vaycore.finance.ui.views.StyledConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    style="@style/mainBg">

    <com.vaycore.finance.ui.views.PageHeaderView
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:centerText="@string/service_provider"
        app:layout_constraintTop_toTopOf="parent" />

    <com.vaycore.finance.ui.views.ContentStateLayout
        android:id="@+id/loading_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="@dimen/dp_15"
        android:paddingTop="@dimen/dp_10"
        app:layout_constraintBottom_toTopOf="@id/bottomActionLayout"
        app:layout_constraintTop_toBottomOf="@id/titleBar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.vaycore.finance.ui.widget.AuthProgressView
                android:id="@+id/authProgressView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginBottom="@dimen/dp_14"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/unAuth_layout"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_0"
                android:layout_marginTop="@dimen/dp_10"
                android:orientation="vertical"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/authProgressView">

                <com.vaycore.finance.ui.views.StyledRecyclerView
                    android:id="@+id/rvService"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:overScrollMode="never"
                    android:paddingTop="@dimen/dp_13"
                    android:paddingBottom="@dimen/dp_25"
                    android:visibility="visible"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:radius="@dimen/dp_12"
                    app:solidColor="@color/transparent"
                    tools:itemCount="5"
                    tools:listitem="@layout/item_service_provider" />
            </LinearLayout>

            <com.vaycore.finance.ui.views.StyledConstraintLayout
                android:id="@+id/auth_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_16"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginBottom="@dimen/dp_30"
                android:paddingBottom="@dimen/dp_42"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/authProgressView"
                app:radius="@dimen/dp_12"
                app:solidColor="@color/white">

                <TextView
                    android:id="@+id/tvTips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dp_30"
                    android:layout_marginTop="@dimen/dp_18"
                    android:text="@string/verify_phone"
                    android:textColor="@color/C_374151"
                    android:textSize="@dimen/sp_16"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.vaycore.finance.ui.views.StyledTextView
                    android:id="@+id/tvPhone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_54"
                    android:layout_marginHorizontal="@dimen/dp_30"
                    android:layout_marginTop="@dimen/dp_12"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/dp_16"
                    android:textColor="@color/C_111827"
                    android:textSize="@dimen/sp_14"
                    app:layout_constraintTop_toBottomOf="@id/tvTips"
                    app:radius="@dimen/dp_6"
                    app:solidColor="@color/C_F6F6F6"
                    tools:text="+09" />

                <TextView
                    android:id="@+id/tvDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dp_30"
                    android:layout_marginTop="@dimen/dp_28"
                    android:text="@string/service_provider"
                    android:textColor="@color/C_374151"
                    android:textSize="@dimen/sp_16"
                    app:layout_constraintTop_toBottomOf="@id/tvPhone" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_30"
                    android:layout_marginTop="@dimen/dp_12"
                    android:src="@mipmap/carrier_viettel"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvDesc" />
            </com.vaycore.finance.ui.views.StyledConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.vaycore.finance.ui.views.ContentStateLayout>

    <LinearLayout
        android:id="@+id/bottomActionLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_20"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible">

        <TextView
            style="@style/AuthDataEncryptedTipText"
            android:layout_gravity="center_horizontal"
            android:layout_marginHorizontal="@dimen/dp_16"
            android:layout_marginBottom="@dimen/dp_10" />

        <com.vaycore.finance.ui.widget.ActionButtonView
            android:id="@+id/btNext"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_48"
            android:layout_marginHorizontal="@dimen/dp_16"
            android:text="@string/click_auth"
            app:actionButtonVariant="filled" />
    </LinearLayout>
</com.vaycore.finance.ui.views.StyledConstraintLayout>
