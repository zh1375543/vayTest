                            android:layout_height="@dimen/dp_46"
                            android:layout_marginEnd="@dimen/dp_12"
                            android:src="@mipmap/ic_apply_tip"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </com.vaycore.finance.ui.views.StyledConstraintLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_90"
                    android:layout_marginTop="@dimen/dp_14"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.vaycore.finance.ui.views.StyledConstraintLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        app:radius="@dimen/dp_24"
                        app:solidColor="@color/white">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/dp_14"
                            android:layout_marginEnd="@dimen/dp_4"
                            android:gravity="start"
                            android:includeFontPadding="false"
                            android:maxLines="3"
                            android:text="@string/home_question3"
                            android:textColor="@color/C_374151"
                            android:textSize="@dimen/sp_14"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/informationTipImage"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/informationTipImage"
                            android:layout_width="@dimen/dp_46"
                            android:layout_height="@dimen/dp_46"
                            android:layout_marginEnd="@dimen/dp_12"
                            android:src="@mipmap/ic_infomation_tip"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </com.vaycore.finance.ui.views.StyledConstraintLayout>

                    <com.vaycore.finance.ui.views.StyledConstraintLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/dp_12"
                        android:layout_weight="1"
                        app:radius="@dimen/dp_24"
                        app:solidColor="@color/white">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/dp_14"
                            android:layout_marginEnd="@dimen/dp_4"
                            android:gravity="start"
                            android:includeFontPadding="false"
                            android:maxLines="3"
                            android:text="@string/home_question2"
                            android:textColor="@color/C_374151"
                            android:textSize="@dimen/sp_14"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/clearTipImage"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/clearTipImage"
                            android:layout_width="@dimen/dp_46"
                            android:layout_height="@dimen/dp_46"
                            android:layout_marginEnd="@dimen/dp_12"
                            android:src="@mipmap/ic_clear_tip"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </com.vaycore.finance.ui.views.StyledConstraintLayout>
                </LinearLayout>
            </LinearLayout>
        </com.vaycore.finance.ui.views.StyledConstraintLayout>

        <com.vaycore.finance.ui.views.StyledConstraintLayout
