<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivCheck"
        android:layout_width="@dimen/dp_17"
        android:layout_height="@dimen/dp_17"
        android:layout_marginStart="@dimen/dp_8"
        android:src="@mipmap/ic_privacy_check_select"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_35"
        android:text="2025/09/21"
        android:textColor="@color/C_374151"
        android:textSize="@dimen/sp_13"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.3" />

    <TextView
        android:id="@+id/tvAmount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="100,000,000₫"
        android:textColor="@color/C_374151"
        android:textSize="@dimen/sp_13"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/tvDate"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.33" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp_4"
        android:gravity="end"
        android:text="@string/settled"
        android:textColor="@color/C_374151"
        android:textSize="@dimen/sp_13"
        app:layout_constraintEnd_toStartOf="@id/ivArrow"
        app:layout_constraintStart_toEndOf="@id/tvAmount"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivArrow"
        android:layout_width="@dimen/dp_22"
        android:layout_height="@dimen/dp_22"
        android:layout_marginEnd="@dimen/dp_9"
        android:src="@mipmap/order_arrow_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.vaycore.finance.ui.widget.VerticalSolidLineView
        android:id="@+id/line"
        android:layout_width="@dimen/dp_1"
        android:layout_height="0dp"
        app:solidLineWidth="@dimen/dp_1"
        app:layout_constraintBottom_toBottomOf="@id/spaceView"
        app:layout_constraintEnd_toEndOf="@id/ivCheck"
        app:layout_constraintStart_toStartOf="@id/ivCheck"
        app:layout_constraintTop_toBottomOf="@id/ivCheck" />

    <com.vaycore.finance.ui.views.StyledConstraintLayout
        android:id="@+id/detail_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_20"
        android:paddingBottom="@dimen/dp_9"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="@id/ivArrow"
        app:layout_constraintStart_toStartOf="@id/tvDate"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:radius="@dimen/dp_4"
        app:solidColor="@color/color_E3E8FF">

        <TextView
            android:id="@+id/tvLoanAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dp_9"
            android:text="$10,000"
            android:textStyle="bold"
            android:textColor="@color/C_374151"
            android:textSize="@dimen/sp_14"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvInterest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_6"
            android:text="21.2"
            android:textStyle="bold"
            android:textColor="@color/C_374151"
            android:textSize="@dimen/sp_14"
            app:layout_constraintEnd_toEndOf="@id/tvLoanAmount"
            app:layout_constraintTop_toBottomOf="@id/tvLoanAmount" />

        <TextView
            android:id="@+id/tvServiceFee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_6"
            android:text="0"
            android:textStyle="bold"
            android:textColor="@color/C_374151"
            android:textSize="@dimen/sp_14"
            app:layout_constraintEnd_toEndOf="@id/tvLoanAmount"
            app:layout_constraintTop_toBottomOf="@id/tvInterest" />

        <TextView
            android:id="@+id/tvDueFee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_6"
            android:text="0"
            android:textColor="@color/C_374151"
            android:textSize="@dimen/sp_14"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@id/tvLoanAmount"
            app:layout_constraintTop_toBottomOf="@id/tvServiceFee" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_9"
            android:text="@string/l_amount"
            android:textColor="@color/C_374151"
            android:textSize="@dimen/sp_13"
            app:layout_constraintBottom_toBottomOf="@id/tvLoanAmount"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvLoanAmount" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_9"
            android:text="@string/interest"
            android:textColor="@color/C_374151"
            android:textSize="@dimen/sp_13"
            app:layout_constraintBottom_toBottomOf="@id/tvInterest"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvInterest" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_9"
            android:text="@string/service_fee"
            android:textColor="@color/C_374151"
            android:textSize="@dimen/sp_13"
            app:layout_constraintBottom_toBottomOf="@id/tvServiceFee"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvServiceFee" />

        <TextView
            android:id="@+id/tvDueFeeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_9"
            android:text="@string/overdue_fee"
            android:textColor="@color/C_374151"
            android:textSize="@dimen/sp_13"
            app:layout_constraintBottom_toBottomOf="@id/tvDueFee"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvDueFee" />

    </com.vaycore.finance.ui.views.StyledConstraintLayout>

    <View
        android:id="@+id/spaceView"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_20"
        android:layout_marginTop="@dimen/dp_m_10"
        app:layout_constraintTop_toBottomOf="@id/detail_layout" />

</androidx.constraintlayout.widget.ConstraintLayout>
