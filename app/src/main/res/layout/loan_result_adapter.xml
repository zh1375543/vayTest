<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_64"
    android:paddingVertical="@dimen/dp_5">

    <com.vaycore.finance.ui.views.StyledTextView
        android:id="@+id/tvName"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dp_24"
        android:layout_marginStart="@dimen/dp_10"
        android:text="loanA"
        android:textColor="@color/C_F62909"
        android:textSize="@dimen/sp_14"
        android:textStyle="bold"
        app:textColorSelected="@color/C_111827"
        app:layout_constraintBottom_toBottomOf="@id/ivStatus"
        app:layout_constraintStart_toEndOf="@id/ivStatus"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvLoanAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_1"
        android:text="@string/loan_amount"
        android:textColor="@color/C_111827"
        android:textSize="@dimen/sp_13"
        app:layout_constraintStart_toStartOf="@id/tvName"
        app:layout_constraintTop_toBottomOf="@id/tvName" />

    <TextView
        android:id="@+id/tvAmount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp_15"
        android:gravity="start"
        android:text="10000"
        android:textColor="@color/C_111827"
        android:textSize="@dimen/sp_16"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tvLoanAmount"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.vaycore.finance.ui.views.SelectableImageView
        android:id="@+id/ivStatus"
        android:layout_width="@dimen/dp_24"
        android:layout_height="@dimen/dp_24"
        android:layout_marginStart="@dimen/dp_6"
        android:layout_marginTop="@dimen/dp_10"
        android:src="@mipmap/img_apply_fail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcSelected="@mipmap/img_apply_pass" />

</androidx.constraintlayout.widget.ConstraintLayout>
