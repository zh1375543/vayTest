<?xml version="1.0" encoding="utf-8"?>
<com.vaycore.finance.ui.views.StyledConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/mainBg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.vaycore.finance.ui.views.PageHeaderView
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:centerText="KYC"
        app:layout_constraintTop_toTopOf="parent" />

    <com.vaycore.finance.ui.views.ContentStateLayout
        android:id="@+id/loading_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.vaycore.finance.ui.widget.AuthProgressView
                android:id="@+id/authProgressView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginBottom="@dimen/dp_14"
                tools:visibility="visible" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <com.vaycore.finance.ui.views.StyledConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <com.vaycore.finance.ui.views.StyledConstraintLayout
                        android:id="@+id/id_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/dp_16"
                        android:paddingBottom="@dimen/dp_23"
                        app:layout_constraintTop_toTopOf="parent"
                        app:radius="@dimen/dp_12"
                        app:solidColor="@color/white">

                        <com.vaycore.finance.ui.views.StyledTextView
                            android:id="@+id/tvCard"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/dp_36"
                            android:layout_marginTop="@dimen/dp_10"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="@dimen/dp_16"
                            android:text="@string/nic_card"
                            app:radius="@dimen/dp_18"
                            android:layout_marginStart="@dimen/dp_12"
                            app:solidColor="@color/color_E3E8FF"
                            android:textColor="@color/C_111827"
                            android:textSize="@dimen/sp_16"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <com.vaycore.finance.ui.views.StyledTextView
                            android:id="@+id/tvExample1"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/dp_28"
                            android:layout_marginStart="@dimen/dp_6"
                            android:layout_marginEnd="@dimen/dp_8"
                            android:drawableEnd="@mipmap/ic_kyc_eye"
                            android:drawablePadding="@dimen/dp_4"
                            android:gravity="center"
                            android:paddingHorizontal="@dimen/dp_15"
                            android:text="@string/view_sample"
                            android:textColor="@color/color_7087F8"
                            android:textSize="@dimen/sp_13"
                            app:layout_constraintBottom_toBottomOf="@id/tvCard"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tvCard" />

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/front_layout"
                            android:layout_marginTop="@dimen/dp_10"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toBottomOf="@id/tvCard">

                            <com.vaycore.finance.ui.views.StyledConstraintLayout
                                android:id="@+id/f_layout"
                                android:layout_width="@dimen/dp_147"
                                android:layout_height="@dimen/dp_83"
                                android:layout_marginStart="@dimen/dp_12"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:radius="@dimen/dp_6"
                                app:solidColor="@color/C_F6F6F6">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:src="@mipmap/pic_id_front"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:src="@mipmap/ic_kyc_creame"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center_horizontal"
                                    android:layout_marginHorizontal="@dimen/dp_2"
                                    android:layout_marginBottom="@dimen/dp_9"
                                    android:autoSizeMaxTextSize="@dimen/sp_12"
                                    android:autoSizeMinTextSize="@dimen/sp_9"
                                    android:autoSizeTextType="uniform"
                                    android:gravity="center"
                                    android:lineSpacingExtra="@dimen/dp_2"
                                    android:maxLines="1"
                                    android:text="@string/upload_nic_card_front"
                                    android:textColor="@color/C_374151"
                                    android:textSize="@dimen/sp_12"
                                    app:layout_constraintBottom_toBottomOf="parent" />

                                <com.google.android.material.imageview.ShapeableImageView
                                    android:id="@+id/ivCardFront"
                                    android:layout_width="0dp"
                                    android:layout_height="0dp"
                                    android:scaleType="fitXY"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:shapeAppearanceOverlay="@style/Round_6" />

                                <FrameLayout
                                    android:id="@+id/frontUp"
                                    android:layout_width="0dp"
                                    android:layout_height="0dp"
                                    android:visibility="gone"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent">

                                    <com.vaycore.finance.ui.views.StyledTextView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        app:radius="@dimen/dp_6"
                                        app:solidColor="@color/p40_FFFFFF" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:drawableTop="@mipmap/icon_close_checked"
                                        android:gravity="center"
                                        android:text="@string/re_up"
                                        android:textColor="@color/white"
                                        android:textSize="@dimen/sp_14" />
                                </FrameLayout>

                            </com.vaycore.finance.ui.views.StyledConstraintLayout>

                            <TextView
                                android:id="@+id/tvFrontTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="@dimen/dp_10"
                                android:text="@string/nic_card_front"
                                android:textColor="@color/C_111827"
                                android:textSize="@dimen/sp_13"
                                android:textStyle="bold"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@id/f_layout"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dp_8"
                                android:text="@string/please_upload_nic_card_front"
                                android:textColor="@color/C_6D7280"
                                android:textSize="@dimen/sp_11"
                                app:layout_constraintEnd_toEndOf="@id/tvFrontTitle"
                                app:layout_constraintStart_toStartOf="@id/tvFrontTitle"
                                app:layout_constraintTop_toBottomOf="@id/tvFrontTitle" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/back_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_10"
                            app:layout_constraintTop_toBottomOf="@id/front_layout">

                            <com.vaycore.finance.ui.views.StyledConstraintLayout
                                android:id="@+id/b_layout"
                                android:layout_width="@dimen/dp_147"
                                android:layout_height="@dimen/dp_83"
                                android:layout_marginStart="@dimen/dp_12"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:radius="@dimen/dp_6"
                                app:solidColor="@color/C_F6F6F6">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:src="@mipmap/pic_id_back"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:src="@mipmap/ic_kyc_creame"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center_horizontal"
                                    android:layout_marginHorizontal="@dimen/dp_2"
                                    android:layout_marginBottom="@dimen/dp_8"
                                    android:autoSizeMaxTextSize="@dimen/sp_12"
                                    android:autoSizeMinTextSize="@dimen/sp_9"
                                    android:autoSizeTextType="uniform"
                                    android:gravity="center"
                                    android:lineSpacingExtra="@dimen/dp_2"
                                    android:maxLines="1"
                                    android:text="@string/upload_nic_card_back"
                                    android:textColor="@color/C_374151"
                                    android:textSize="@dimen/sp_12"
                                    app:layout_constraintBottom_toBottomOf="parent" />

                                <com.google.android.material.imageview.ShapeableImageView
                                    android:id="@+id/ivCardBack"
                                    android:layout_width="0dp"
                                    android:layout_height="0dp"
                                    android:scaleType="fitXY"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:shapeAppearanceOverlay="@style/Round_6" />

                                <FrameLayout
                                    android:id="@+id/backUp"
                                    android:layout_width="0dp"
                                    android:layout_height="0dp"
                                    android:visibility="gone"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent">

                                    <com.vaycore.finance.ui.views.StyledTextView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        app:radius="@dimen/dp_6"
                                        app:solidColor="@color/p40_FFFFFF" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:drawableTop="@mipmap/icon_close_checked"
                                        android:gravity="center"
                                        android:text="@string/re_up"
                                        android:textColor="@color/white"
                                        android:textSize="@dimen/sp_14" />
                                </FrameLayout>

                            </com.vaycore.finance.ui.views.StyledConstraintLayout>

                            <TextView
                                android:id="@+id/tvBackTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="@dimen/dp_10"
                                android:text="@string/nic_card_back"
                                android:textColor="@color/C_111827"
                                android:textSize="@dimen/sp_13"
                                android:textStyle="bold"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@id/b_layout"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dp_8"
                                android:text="@string/please_upload_nic_card_back"
                                android:textColor="@color/C_6D7280"
                                android:textSize="@dimen/sp_11"
                                app:layout_constraintEnd_toEndOf="@id/tvBackTitle"
                                app:layout_constraintStart_toStartOf="@id/tvBackTitle"
                                app:layout_constraintTop_toBottomOf="@id/tvBackTitle" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </com.vaycore.finance.ui.views.StyledConstraintLayout>

                    <com.vaycore.finance.ui.views.StyledConstraintLayout
                        android:id="@+id/selfGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/dp_16"
                        android:layout_marginTop="@dimen/dp_12"

                        app:layout_constraintTop_toBottomOf="@id/id_layout"
                        app:radius="@dimen/dp_12"
                        app:solidColor="@color/white">

                        <com.vaycore.finance.ui.views.StyledTextView
                            android:id="@+id/tvSelf"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/dp_36"
                            android:layout_marginTop="@dimen/dp_10"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="@dimen/dp_16"
                            android:text="@string/self_photo"
                            android:layout_marginHorizontal="@dimen/dp_12"
                            app:solidColor="@color/color_E3E8FF"
                            android:textColor="@color/C_111827"
                            android:textSize="@dimen/sp_16"
                            app:radius="@dimen/dp_18"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <com.vaycore.finance.ui.views.StyledTextView
                            android:id="@+id/tvExample2"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/dp_28"
                            android:layout_marginStart="@dimen/dp_6"
                            android:layout_marginEnd="@dimen/dp_8"
                            android:drawableEnd="@mipmap/ic_kyc_eye"
                            android:drawablePadding="@dimen/dp_4"
                            android:gravity="center"
                            android:paddingHorizontal="@dimen/dp_15"
                            android:text="@string/view_sample"
                            android:textColor="@color/color_7087F8"
                            android:textSize="@dimen/sp_13"
                            app:layout_constraintBottom_toBottomOf="@id/tvSelf"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tvSelf" />

                        <TextView
                            android:id="@+id/tvSelfDesc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_10"
                            android:layout_marginHorizontal="@dimen/dp_12"
                            android:lineSpacingExtra="@dimen/dp_4"
                            android:text="@string/self_photo_tips"
                            android:textColor="@color/C_6D7280"
                            android:textSize="@dimen/sp_12"
                            android:visibility="visible"
                            app:layout_constraintTop_toBottomOf="@id/tvSelf" />

                        <com.vaycore.finance.ui.views.StyledConstraintLayout
                            android:id="@+id/self_layout"
                            android:layout_width="@dimen/dp_165"
                            android:layout_height="@dimen/dp_145"
                            android:layout_marginTop="@dimen/dp_16"
                            android:layout_marginBottom="@dimen/dp_100"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvSelfDesc"
                            app:radius="@dimen/dp_6"
                            app:solidColor="@color/C_F6F6F6">

                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@mipmap/pic_id_portrait"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@mipmap/ic_kyc_creame"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginHorizontal="@dimen/dp_2"
                                android:layout_marginBottom="@dimen/dp_9"
                                android:autoSizeMaxTextSize="@dimen/sp_12"
                                android:autoSizeMinTextSize="@dimen/sp_9"
                                android:autoSizeTextType="uniform"
                                android:gravity="center"
                                android:text="@string/upload_self_photo"
                                android:textColor="@color/C_374151"
                                android:textSize="@dimen/sp_12"
                                app:layout_constraintBottom_toBottomOf="parent" />

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/ivSelf"
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:scaleType="fitXY"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:shapeAppearanceOverlay="@style/Round_6" />

                            <FrameLayout
                                android:id="@+id/selfUp"
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:visibility="gone"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent">

                                <com.vaycore.finance.ui.views.StyledTextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    app:radius="@dimen/dp_6"
                                    app:solidColor="@color/p40_FFFFFF" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:drawableTop="@mipmap/icon_close_checked"
                                    android:gravity="center"
                                    android:text="@string/re_up"
                                    android:textColor="@color/white"
                                    android:textSize="@dimen/sp_14" />
                            </FrameLayout>

                        </com.vaycore.finance.ui.views.StyledConstraintLayout>
                    </com.vaycore.finance.ui.views.StyledConstraintLayout>
                </com.vaycore.finance.ui.views.StyledConstraintLayout>
            </androidx.core.widget.NestedScrollView>

            <LinearLayout
                android:id="@+id/bottomActionLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="@dimen/dp_15"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    style="@style/AuthDataEncryptedTipText"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:layout_marginBottom="@dimen/dp_10" />

                <com.vaycore.finance.ui.widget.ActionButtonView
                    android:id="@+id/btNext"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_48"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:text="@string/next"
                    app:actionButtonVariant="filled" />
            </LinearLayout>
        </LinearLayout>
    </com.vaycore.finance.ui.views.ContentStateLayout>
</com.vaycore.finance.ui.views.StyledConstraintLayout>
