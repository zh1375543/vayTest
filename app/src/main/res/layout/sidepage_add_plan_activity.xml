<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@mipmap/ic_page_bg">

    <com.vaycore.finance.ui.views.PageHeaderView
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:centerText="@string/portal_add_plan_title"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/dp_20"
        app:layout_constraintBottom_toTopOf="@id/bottomActionLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleBar">

        <com.vaycore.finance.ui.views.StyledLinearLayout
            android:id="@+id/formCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_marginTop="@dimen/dp_16"
            android:layout_marginEnd="@dimen/dp_16"
            android:orientation="vertical"
            android:paddingTop="@dimen/dp_14"
            android:paddingBottom="@dimen/dp_22"
            app:radius="@dimen/dp_24"
            app:solidColor="@color/white">

            <com.vaycore.finance.ui.widget.FormItemView
                android:id="@+id/planNameView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:editMaxLength="50"
                app:errorText="@string/portal_please_enter_plan_name"
                app:formType="input"
                app:hintText="@string/please_enter"
                app:inputType="text"
                app:titleText="@string/portal_plan_name" />

            <com.vaycore.finance.ui.widget.FormItemView
                android:id="@+id/targetAmountView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:editMaxLength="12"
                app:errorText="@string/portal_please_enter_target_amount"
                app:formType="input"
                app:hintText="@string/please_enter"
                app:inputType="number"
                app:titleText="@string/portal_target_amount" />

            <com.vaycore.finance.ui.widget.FormItemView
                android:id="@+id/frequencyView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:errorText="@string/portal_please_choose_frequency"
                app:formType="select"
                app:hintText="@string/please_choose"
                app:inputType="text"
                app:titleText="@string/portal_saving_frequency" />

            <com.vaycore.finance.ui.widget.FormItemView
                android:id="@+id/eachAmountView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:editMaxLength="12"
                app:errorText="@string/portal_please_enter_each_amount"
                app:formType="input"
                app:hintText="@string/please_enter"
                app:inputType="number"
                app:titleText="@string/portal_each_saving_amount" />

            <TextView
                android:id="@+id/tvPlanIconTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_16"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginEnd="@dimen/dp_16"
                android:text="@string/portal_plan_icon"
                android:textColor="@color/C_374151"
                android:textSize="@dimen/sp_14"
                android:textStyle="bold" />

            <com.vaycore.finance.ui.views.StyledConstraintLayout
                android:id="@+id/iconUploadView"
                android:layout_width="@dimen/dp_104"
                android:layout_height="@dimen/dp_104"
                android:layout_marginStart="@dimen/dp_16"
                android:layout_marginTop="@dimen/dp_10"
                android:clickable="true"
                android:focusable="true"
                app:autoFillPressedColor="true"
                app:radius="@dimen/dp_16"
                app:solidColor="@color/C_F6F6F6">

                <ImageView
                    android:id="@+id/ivPlanIcon"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:contentDescription="@string/portal_plan_icon"
                    android:padding="@dimen/dp_36"
                    android:scaleType="centerCrop"
                    android:src="@mipmap/ic_at_upload"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/ivUploadStatus"
                    android:layout_width="@dimen/dp_28"
                    android:layout_height="@dimen/dp_28"
                    android:contentDescription="@string/portal_plan_icon"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </com.vaycore.finance.ui.views.StyledConstraintLayout>

        </com.vaycore.finance.ui.views.StyledLinearLayout>

    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomActionLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/dp_16"
        android:paddingTop="@dimen/dp_12"
        android:paddingEnd="@dimen/dp_16"
        android:paddingBottom="@dimen/dp_16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.vaycore.finance.ui.widget.ActionButtonView
            android:id="@+id/btStartPlan"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_52"
            android:text="@string/portal_start_savings_plan"
            app:actionButtonVariant="filled" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
