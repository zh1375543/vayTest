<?xml version="1.0" encoding="utf-8"?>
<com.vaycore.finance.ui.views.StyledConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/dp_20"
    android:gravity="center"
    android:orientation="vertical"
    app:radius="@dimen/dp_24"
    app:gradientStartColor="@color/white"
    app:gradientEndColor="@color/white"
    app:gradientOrientation="TOP_BOTTOM">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_16"
        android:layout_marginTop="@dimen/dp_16"
        android:gravity="center"
        android:text="@string/new_version"
        android:textColor="@color/C_111827"
        android:textSize="@dimen/sp_28"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_16"
        android:gravity="center"
        android:textColor="@color/C_6D7280"
        android:text="@string/new_version_desc"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <com.vaycore.finance.ui.views.StyledTextView
        android:id="@+id/tvOK"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_48"
        android:layout_marginHorizontal="@dimen/dp_34"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_marginBottom="@dimen/dp_15"
        style="@style/mainButton"
        android:text="@string/update"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDesc" />
</com.vaycore.finance.ui.views.StyledConstraintLayout>