<?xml version="1.0" encoding="utf-8"?>
<com.vaycore.finance.ui.views.StyledConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/dp_10"
    android:paddingBottom="@dimen/dp_16"
    app:radius="@dimen/dp_12"
    app:solidColor="@color/white">

    <com.vaycore.finance.ui.views.StyledTextView
        android:id="@+id/tvName"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_40"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingHorizontal="@dimen/dp_12"
        android:text="Loan A"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_14"
        android:textStyle="bold"
        android:gravity="center"
        app:solidColor="@color/color_7087F8"
        app:left_top_radius="@dimen/dp_12"
        app:right_top_radius="@dimen/dp_12"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <TextView
        android:id="@+id/tvProductDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp_12"
        android:drawablePadding="@dimen/dp_2"
        android:gravity="center_vertical"
        android:layout_marginStart="@dimen/dp_12"
        android:drawableEnd="@mipmap/ic_mine_arrow"
        android:text="@string/product_details"
        android:textColor="@color/C_111827"
        android:textSize="@dimen/sp_12"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        android:paddingVertical="@dimen/dp_12"/>

    <com.vaycore.finance.ui.views.SelectableImageView
        android:id="@+id/ivCheck"
        android:layout_width="@dimen/dp_24"
        android:layout_height="@dimen/dp_24"
        android:layout_marginEnd="@dimen/dp_12"
        android:src="@mipmap/icon_close_unchecked"
        app:layout_constraintBottom_toBottomOf="@id/tvProductDetail"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcSelected="@mipmap/icon_close_checked" />

    <TextView
        android:id="@+id/tvLoanAmount"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dp_17"
        android:layout_marginStart="@dimen/dp_12"
        android:gravity="center_vertical"
        android:text="@string/total_repayment"
        android:textColor="@color/C_374151"
        android:layout_marginTop="@dimen/dp_15"
        android:textSize="@dimen/sp_13"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvName" />

    <TextView
        android:id="@+id/tvOrderStatusTitle"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dp_17"
        android:layout_marginTop="@dimen/dp_6"
        android:gravity="center_vertical"
        android:text="@string/order_status"
        android:textColor="@color/C_374151"
        android:textSize="@dimen/sp_13"
        app:layout_constraintStart_toStartOf="@id/tvLoanAmount"
        app:layout_constraintTop_toBottomOf="@id/tvLoanAmount" />

    <com.vaycore.finance.ui.views.StyledTextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/overdue"
        android:textColor="@color/C_FA560D"
        app:textColorSelected="@color/C_F62909"
        android:textSize="@dimen/sp_14"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="@dimen/dp_12"
        app:layout_constraintTop_toTopOf="@id/tvOrderStatusTitle" />

    <TextView
        android:id="@+id/tvAmount"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dp_17"
        android:text="200,000,000 ₫"
        android:textColor="@color/C_111827"
        android:textSize="@dimen/sp_14"
        android:layout_marginEnd="@dimen/dp_12"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvLoanAmount" />
</com.vaycore.finance.ui.views.StyledConstraintLayout>
